# Copy this file to ".env" and fill in your real values.
# The real ".env" is git-ignored and must NEVER be committed.
#
# Get your key at https://comtradedeveloper.un.org/ (free "comtrade - v1" tier).
COMTRADE_API_KEY=your_primary_key_here

# AWS region we'll use (set on Day 1). us-east-1 chosen for widest free-tier + service coverage.
AWS_REGION=us-east-1
